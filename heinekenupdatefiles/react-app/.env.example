# Postgres connection string used by Prisma at runtime.
DATABASE_URL=

# Only required locally when running `npx prisma migrate dev` (Prisma needs a
# throwaway "shadow" database to diff migrations against). Not needed in
# production. `prisma migrate deploy` doesn't use it.
SHADOW_DATABASE_URL=

# Simple shared-password admin login (single password, no per-user accounts).
ADMIN_PASSWORD=

# Random 32+ character string used to sign admin/staff session cookies.
# Generate with: openssl rand -base64 32
SESSION_SECRET=

# Public site URL. Used to build absolute links in emails (logo, "view QR"
# fallback, calendar) and the check-in QR code embedded in confirmation
# emails. Set to your deployed Vercel URL in production.
SITE_URL=http://localhost:3000

# Gmail SMTP, used to send RSVP confirmation emails (with the entry QR code
# attached) when a guest accepts.
# 1. Enable 2-Step Verification on the Gmail account.
# 2. Create an "App Password" at https://myaccount.google.com/apppasswords
# 3. Use that 16-character app password below (not your normal Gmail password).
GMAIL_USER=
GMAIL_APP_PASSWORD=
